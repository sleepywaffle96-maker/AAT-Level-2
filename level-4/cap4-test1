<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>External Auditing - Test One</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #e3e3e3;
            margin: 0;
            padding: 40px 20px;
            display: flex;
            justify-content: center;
        }
        .quiz-container {
            width: 100%;
            max-width: 750px;
            background-color: #ffffff;
            border: 1px solid #999999;
            padding: 25px;
            box-shadow: 2px 2px 8px rgba(0,0,0,0.1);
        }
        .header-title {
            color: #006633;
            font-size: 18px;
            font-weight: bold;
            border-bottom: 2px solid #006633;
            padding-bottom: 8px;
            margin-bottom: 20px;
        }
        .question-page {
            display: none;
            min-height: 220px;
        }
        .question-page.active {
            display: block;
        }
        .question-counter {
            font-size: 13px;
            font-weight: bold;
            color: #333333;
            margin-bottom: 15px;
        }
        .question-body {
            font-size: 14px;
            line-height: 1.6;
            color: #222222;
        }
        select, input[type="text"] {
            padding: 4px;
            font-size: 13px;
            border: 1px solid #999999;
            border-radius: 2px;
            margin: 4px 0;
        }
        input[type="text"] {
            width: 110px;
            text-align: right;
            font-family: monospace;
        }
        .nav-buttons {
            margin-top: 30px;
            border-top: 1px solid #cccccc;
            padding-top: 15px;
            display: flex;
            justify-content: space-between;
        }
        .btn-action {
            background-color: #f0f0f0;
            border: 1px solid #999999;
            padding: 4px 14px;
            font-size: 13px;
            cursor: pointer;
            color: #333333;
        }
        .btn-action:hover {
            background-color: #e0e0e0;
        }
        .feedback {
            margin-top: 15px;
            font-size: 14px;
            font-weight: bold;
        }
        .correct { color: #006633; }
        .incorrect { color: #cc0000; }
    </style>
</head>
<body>

<div class="quiz-container">
    <div class="header-title">External Auditing - Test One</div>

    <!-- Q1 -->
    <div id="page1" class="question-page active">
        <div class="question-counter">Q1 of 15</div>
        <div class="question-body">
            An audit team calculates performance materiality for a new assignment. Profit before tax is £800,000. Following international guidelines, the firm sets overall planning materiality at 5% of profit before tax. Calculate the baseline planning materiality threshold:<br>
            Planning Materiality: £ <input type="text" id="ans1" placeholder="0.00">
        </div>
    </div>

    <!-- Q2 -->
    <div id="page2" class="question-page">
        <div class="question-counter">Q2 of 15</div>
        <div class="question-body">
            The mathematical model for Audit Risk determines that Audit Risk = Inherent Risk &times; Control Risk &times; Detection Risk. If an auditor assesses Inherent Risk as high and Control Risk as high, what directional strategy must be applied to Detection Risk to keep overall Audit Risk low?<br>
            Detection Risk must be: <select id="ans2"><option value="">Select</option><option value="w">Increased</option><option value="correct">Decreased (Lowered)</option><option value="w">Kept completely unchanged</option></select>
        </div>
    </div>

    <!-- Q3 -->
    <div id="page3" class="question-page">
        <div class="question-counter">Q3 of 15</div>
        <div class="question-body">
            During the year-end inventory count, an auditor selects 40 physical stock items from the warehouse floor and traces them back to the company's draft stock sheets. Which specific financial statement assertion is being tested?<br>
            Assertion Type: <select id="ans3"><option value="">Select</option><option value="w">Existence</option><option value="correct">Completeness</option><option value="w">Valuation and Allocation</option></select>
        </div>
    </div>

    <!-- Q4 -->
    <div id="page4" class="question-page">
        <div class="question-counter">Q4 of 15</div>
        <div class="question-body">
            An auditor wishes to test the internal controls within the sales ledger cycle. They select a sample of sales invoices and verify whether each invoice has been signed by the credit control manager. This procedure is legally defined as a:<br>
            Procedure Category: <select id="ans4"><option value="">Select</option><option value="correct">Test of Control</option><option value="w">Substantive Analytical Procedure</option><option value="w">Test of Detail</option></select>
        </div>
    </div>

    <!-- Q5 -->
    <div id="page5" class="question-page">
        <div class="question-counter">Q5 of 15</div>
        <div class="question-body">
            A corporate entity has credit sales of £1,200,000 and total closing trade receivables of £240,000. Calculate the Receivables Turnover Ratio to be used during the initial analytical procedures stage:<br>
            Receivables Turnover: <input type="text" id="ans5" placeholder="0.0"> times
        </div>
    </div>

    <!-- Q6 -->
    <div id="page6" class="question-page">
        <div class="question-counter">Q6 of 15</div>
        <div class="question-body">
            The risk that the auditor's substantive procedures will fail to detect a material misstatement that exists in an financial ledger assertion is defined as:<br>
            Risk Category: <select id="ans6"><option value="">Select</option><option value="w">Inherent Risk</option><option value="w">Control Risk</option><option value="correct">Detection Risk</option></select>
        </div>
    </div>

    <!-- Q7 -->
    <div id="page7" class="question-page">
        <div class="question-counter">Q7 of 15</div>
        <div class="question-body">
            When auditing payroll, an auditor compares the current year's total wage expense against the prior year's audited figures, adjusted for inflation and changes in headcount. This structural verification process represents a:<br>
            Procedure Category: <select id="ans7"><option value="">Select</option><option value="w">Test of Control</option><option value="correct">Substantive Analytical Procedure</option><option value="w">Risk Assessment Procedure</option></select>
        </div>
    </div>

    <!-- Q8 -->
    <div id="page8" class="question-page">
        <div class="question-counter">Q8 of 15</div>
        <div class="question-body">
            According to ISA 505 External Confirmations, if a debtor fails to respond to a positive circularization request, the auditor can accept the ledger balance as correct if the client provides a verbal confirmation.<br>
            Is this statement True or False?<br>
            Answer: <select id="ans8"><option value="">Select</option><option value="w">True</option><option value="correct">False</option></select>
        </div>
    </div>
          
    <!-- Q9 -->
    <div id="page9" class="question-page">
        <div class="question-counter">Q9 of 15</div>
        <div class="question-body">
            An auditor extracts a sample from the total population of purchase vouchers. The total number of items is 2,500, and the auditor intends to select every 50th item after a random starting point. What sampling methodology is being applied?<br>
            Methodology Type: <select id="ans9"><option value="">Select</option><option value="w">Random Selection</option><option value="correct">Systematic Selection</option><option value="w">Haphazard Selection</option></select>
        </div>
    </div>

    <!-- Q10 -->
    <div id="page10" class="question-page">
        <div class="question-counter">Q10 of 15</div>
        <div class="question-body">
            A serious material misstatement is discovered regarding an omitted loan liability of £250,000. The effect is material but not pervasive to the financial statements. State the type of modified audit opinion that the auditor must issue:<br>
            Opinion Type: <select id="ans10"><option value="">Select</option><option value="correct">Qualified Opinion ("Except for")</option><option value="w">Adverse Opinion</option><option value="w">Disclaimer of Opinion</option></select>
        </div>
    </div>

    <!-- Q11 -->
    <div id="page11" class="question-page">
        <div class="question-counter">Q11 of 15</div>
        <div class="question-body">
            The working papers prepared by an audit team to document the evidence collected during an assignment remain the legal property of the audit firm, not the client company.<br>
            Is this statement True or False?<br>
            Answer: <select id="ans11"><option value="">Select</option><option value="correct">True</option><option value="w">False</option></select>
        </div>
    </div>

    <!-- Q12 -->
    <div id="page12" class="question-page">
        <div class="question-counter">Q12 of 15</div>
        <div class="question-body">
            An auditor attends the year-end stock count and selects 30 items from the client's inventory inventory list, then physically finds and counts those specific items on the warehouse shelves. Which specific financial statement assertion is being tested?<br>
            Assertion Type: <select id="ans12"><option value="">Select</option><option value="correct">Existence</option><option value="w">Completeness</option><option value="w">Rights and Obligations</option></select>
        </div>
    </div>

    <!-- Q13 -->
    <div id="page13" class="question-page">
        <div class="question-counter">Q13 of 15</div>
        <div class="question-body">
            A limited company is facing severe cash flow issues, and its bank refuses to renew the overdraft facility. Under ISA 570, the auditor must explicitly evaluate whether there is substantial doubt about the company's ability to continue as a:<br>
            Accounting Principle: <select id="ans13"><option value="">Select</option><option value="w">Accrual Basis entity</option><option value="correct">Going Concern</option><option value="w">Separate Legal Entity</option></select>
        </div>
    </div>

    <!-- Q14 -->
    <div id="page14" class="question-page">
        <div class="question-counter">Q14 of 15</div>
        <div class="question-body">
            An audit firm discovers that a client's internal IT controls are extremely weak, allowing any user to alter historical transaction records. This deficiency will directly increase which component of the audit risk model?<br>
            Risk Component: <select id="ans14"><option value="">Select</option><option value="w">Inherent Risk</option><option value="correct">Control Risk</option><option value="w">Detection Risk</option></select>
        </div>
    </div>

    <!-- Q15 -->
    <div id="page15" class="question-page">
        <div class="question-counter">Q15 of 15</div>
        <div class="question-body">
            During an external audit, the team discovers widespread, systemic fraudulent accounting entries across multiple asset accounts. The total effect is material and completely pervasive, misleading the entire financial report. State the type of opinion required:<br>
            Opinion Type: <select id="ans15"><option value="">Select</option><option value="w">Qualified Opinion</option><option value="correct">Adverse Opinion</option><option value="w">Disclaimer of Opinion</option></select>
        </div>
    </div>

    <!-- Feedback e Navigazione -->
    <div id="feedbackBox" class="feedback"></div>

    <div class="nav-buttons">
        <button class="btn-action" id="backBtn" onclick="changePage(-1)">Back</button>
        <button class="btn-action" onclick="checkCurrentAnswer()">Check Answer</button>
        <button class="btn-action" id="nextBtn" onclick="changePage(1)">Next</button>
    </div>
</div>

<script>
    let currentQ = 1;
    const totalQ = 15;

    function updateButtons() {
        document.getElementById('backBtn').style.visibility = (currentQ === 1) ? 'hidden' : 'visible';
        document.getElementById('nextBtn').style.visibility = (currentQ === totalQ) ? 'hidden' : 'visible';
        document.getElementById('feedbackBox').innerText = '';
    }

    function changePage(step) {
        if ((currentQ + step) >= 1 && (currentQ + step) <= totalQ) {
            document.getElementById(`page${currentQ}`).classList.remove('active');
            currentQ += step;
            document.getElementById(`page${currentQ}`).classList.add('active');
            updateButtons();
        }
    }

    function checkCurrentAnswer() {
        let isCorrect = false;
        let feedback = document.getElementById('feedbackBox');

        if (currentQ === 1) {
            let val = document.getElementById('ans1').value.trim();
            isCorrect = (val === '40000' || val === '40000.00');
        } else if (currentQ === 2) {
            isCorrect = (document.getElementById('ans2').value === 'correct');
        } else if (currentQ === 3) {
            isCorrect = (document.getElementById('ans3').value === 'correct');
        } else if (currentQ === 4) {
            isCorrect = (document.getElementById('ans4').value === 'correct');
        } else if (currentQ === 5) {
            let val = document.getElementById('ans5').value.trim();
            isCorrect = (val === '5' || val === '5.0' || val === '5.00');
        } else if (currentQ === 6) {
            isCorrect = (document.getElementById('ans6').value === 'correct');
        } else if (currentQ === 7) {
            isCorrect = (document.getElementById('ans7').value === 'correct');
        } else if (currentQ === 8) {
            isCorrect = (document.getElementById('ans8').value === 'correct');
        } else if (currentQ === 9) {
            isCorrect = (document.getElementById('ans9').value === 'correct');
        } else if (currentQ === 10) {
            isCorrect = (document.getElementById('ans10').value === 'correct');
        } else if (currentQ === 11) {
            isCorrect = (document.getElementById('ans11').value === 'correct');
        } else if (currentQ === 12) {
            isCorrect = (document.getElementById('ans12').value === 'correct');
        } else if (currentQ === 13) {
            isCorrect = (document.getElementById('ans13').value === 'correct');
        } else if (currentQ === 14) {
            isCorrect = (document.getElementById('ans14').value === 'correct');
        } else if (currentQ === 15) {
            isCorrect = (document.getElementById('ans15').value === 'correct');
        }

        if (isCorrect) {
            feedback.innerHTML = '<span class="correct">Correct! Well done.</span>';
        } else {
            feedback.innerHTML = '<span class="incorrect">Incorrect. Please try again.</span>';
        }
    }

    updateButtons();
</script>

</body>
</html>
